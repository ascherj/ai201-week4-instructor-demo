# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit your real API key.

# Required: your OpenRouter API key
# Get one free at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: override the default model
# Default is meta-llama/llama-3.1-8b-instruct — a small paid model that returns
# reliable JSON verdicts. A full notebook run costs a fraction of a cent.
# For Week 4, use the shared course OpenRouter key (it has credits).
#
# Free models exist but their shared providers throttle unpredictably (HTTP 429)
# and sometimes return degraded output, so they're unreliable for the demo.
# To try one anyway:
# OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free
